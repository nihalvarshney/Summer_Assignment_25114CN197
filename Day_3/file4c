#include <stdio.h>
int main() 
{
    int a, b, gcd, lcm, tempA, tempB;
    printf("Enter two numbers: ");
    scanf("%d %d", &a, &b);
    tempA = a;
    tempB = b;
    while (b != 0) 
    {
        int temp = b;
        b = a % b;
        a = temp;
    }
    gcd = a;
    lcm = (tempA * tempB) / gcd;
    printf("LCM = %d", lcm);
    return 0;
}
